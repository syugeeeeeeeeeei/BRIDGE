{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridge.local/schemas/benchmark-execution-manifest-v1.schema.json",
  "title": "BRIDGE Benchmark Execution Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "execution_id",
    "suite_id",
    "scenario_schema_version",
    "observation_mode",
    "started_at",
    "completed_at",
    "output_directory",
    "run_order",
    "integrity_algorithm",
    "artifact_files"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.benchmark.execution.v1"
    },
    "execution_id": {
      "type": "string"
    },
    "suite_id": {
      "type": "string"
    },
    "scenario_schema_version": {
      "const": "bridge.benchmark.v1"
    },
    "observation_mode": {
      "enum": [
        "off",
        "minimum",
        "debug",
        "trace"
      ]
    },
    "started_at": {
      "type": "string"
    },
    "completed_at": {
      "type": "string"
    },
    "output_directory": {
      "type": "string"
    },
    "run_order": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integrity_algorithm": {
      "const": "sha256"
    },
    "artifact_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "size_bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string",
            "minLength": 1
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          },
          "sha256": {
            "type": "string",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
