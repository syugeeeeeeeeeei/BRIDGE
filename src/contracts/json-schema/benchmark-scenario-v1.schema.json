{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridge.local/schemas/benchmark-scenario-v2.schema.json",
  "title": "BRIDGE Benchmark Scenario v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "suite",
    "execution",
    "algorithms",
    "scenarios"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.benchmark.v2"
    },
    "suite": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repetitions": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "warmup_runs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "seeds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer"
          }
        },
        "jobs": {
          "const": 1
        },
        "timeout": {
          "type": "string"
        },
        "randomize_order": {
          "type": "boolean"
        }
      }
    },
    "algorithms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "enum": [
          "bridge",
          "anchor",
          "dijkstra",
          "bidirectional_dijkstra",
          "astar",
          "weighted_astar",
          "reachability"
        ]
      }
    },
    "observation_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "enum": [
            "off",
            "summary",
            "trace",
            "profile"
          ]
        },
        "sample_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        }
      }
    },
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "output_dir": {
          "type": "string",
          "minLength": 1
        },
        "artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "save_raw_results": {
          "type": "boolean"
        },
        "save_trace": {
          "type": "boolean"
        },
        "capture_environment": {
          "type": "boolean"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "acceptance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "path_found_rate_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "optimality_proven_rate_min": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "mean_work_actions_max": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scenario"
      }
    }
  },
  "$defs": {
    "query": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "query_selection_method": {
          "enum": [
            "generator_default_endpoints",
            "explicit_endpoints"
          ]
        },
        "source": {
          "type": "integer",
          "minimum": 0
        },
        "target": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "scenario": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "graph"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "graph": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "generator": {
              "enum": [
                "grid",
                "random_geometric",
                "community",
                "maze",
                "adversarial",
                "dataset"
              ]
            },
            "requested_node_count": {
              "type": "integer",
              "minimum": 2
            },
            "width": {
              "type": "integer",
              "minimum": 1
            },
            "height": {
              "type": "integer",
              "minimum": 1
            },
            "topology": {
              "enum": [
                "open",
                "wall",
                "u_shape",
                "culdesac",
                "disconnected"
              ]
            },
            "neighbor_candidate_count": {
              "type": "integer",
              "minimum": 0
            },
            "edge_weight_noise": {
              "type": "number",
              "minimum": 0
            },
            "community_count": {
              "type": "integer",
              "minimum": 0
            },
            "dataset_path": {
              "type": "string",
              "minLength": 1
            },
            "dataset_format": {
              "enum": [
                "bridge.dataset.v1.json"
              ]
            }
          }
        },
        "endpoints": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "query_selection_method": {
              "enum": [
                "generator_default_endpoints",
                "explicit_endpoints"
              ]
            },
            "source": {
              "type": "integer",
              "minimum": 0
            },
            "target": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "queries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/query"
          }
        },
        "route": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "route_mode": {
              "enum": [
                "fast",
                "balanced",
                "quality",
                "exact"
              ]
            },
            "logical_worker_count": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "budget": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "total_work": {
              "type": "integer",
              "minimum": 1
            },
            "timeout_ms": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          }
        },
        "ablation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disable_fallback": {
              "type": "boolean"
            },
            "disable_certification": {
              "type": "boolean"
            },
            "disable_detour": {
              "type": "boolean"
            },
            "disable_budget_reallocation": {
              "type": "boolean"
            },
            "disable_state_reuse": {
              "type": "boolean"
            }
          }
        }
      }
    }
  }
}
