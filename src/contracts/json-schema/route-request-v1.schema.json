{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "bridge.route.request.v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "graph",
    "route"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.route.request.v1"
    },
    "request_id": {
      "type": "string"
    },
    "graph": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "enum": [
            "inline",
            "file"
          ]
        },
        "directed": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "integer",
                "minimum": 0
              },
              "x": {
                "type": "number"
              },
              "y": {
                "type": "number"
              }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "from",
              "to",
              "weight"
            ],
            "properties": {
              "from": {
                "type": "integer",
                "minimum": 0
              },
              "to": {
                "type": "integer",
                "minimum": 0
              },
              "weight": {
                "type": "number",
                "exclusiveMinimum": 0
              }
            }
          }
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target"
      ],
      "properties": {
        "source": {
          "type": "integer",
          "minimum": 0
        },
        "target": {
          "type": "integer",
          "minimum": 0
        },
        "route_mode": {
          "enum": [
            "fast",
            "balanced",
            "quality",
            "exact"
          ]
        },
        "max_suboptimality": {
          "type": "number",
          "minimum": 1
        },
        "logical_worker_count": {
          "type": "integer",
          "minimum": 1
        },
        "seed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "total_work": {
          "type": "integer",
          "minimum": 1
        },
        "timeout_ms": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "observation_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "enum": [
            "off",
            "aggregate",
            "trace"
          ]
        }
      }
    }
  }
}
