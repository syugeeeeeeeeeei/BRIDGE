{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridge.local/schemas/benchmark-graph-snapshot-v1.schema.json",
  "title": "BRIDGE Benchmark Graph Snapshot v1",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "graph", "source", "target"],
  "properties": {
    "schema_version": {"const": "bridge.graph.snapshot.v1"},
    "source": {"type": "integer", "minimum": 0}, "target": {"type": "integer", "minimum": 0},
    "graph": {"type": "object", "required": ["type", "nodes", "edges"], "properties": {"type": {"const": "inline"}, "directed": {"type": "boolean"}, "nodes": {"type": "array"}, "edges": {"type": "array"}}, "additionalProperties": true}
  }
}
