{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridge.local/schemas/route-result-v2.schema.json",
  "title": "BRIDGE Route Result v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "status",
    "path_found",
    "path",
    "optimality_proven",
    "work",
    "end_to_end_time_ms",
    "solver_time_ms",
    "time_breakdown"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.route.result.v2"
    },
    "request_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "found",
        "unreachable",
        "budget_exhausted",
        "timeout"
      ]
    },
    "path_found": {
      "type": "boolean"
    },
    "path_cost": {
      "type": "number",
      "minimum": 0
    },
    "path": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      }
    },
    "search_completed": {
      "type": "boolean"
    },
    "reachability_proven": {
      "type": "boolean"
    },
    "optimality_proven": {
      "type": "boolean"
    },
    "solver_name": {
      "type": "string"
    },
    "work": {
      "type": "object"
    },
    "end_to_end_time_ms": {
      "type": "number",
      "minimum": 0
    },
    "error_code": {
      "type": "string"
    },
    "observation_data": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "level",
        "event_count",
        "truncated"
      ],
      "properties": {
        "level": {
          "enum": [
            "off",
            "summary",
            "trace",
            "profile"
          ]
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "dropped_events": {
          "type": "integer",
          "minimum": 0
        },
        "truncated": {"type": "boolean"},
        "overhead_ns": {"type": "integer", "minimum": 0},
        "sink_write_ns": {"type": "integer", "minimum": 0},
        "summary": {"type": "object"}
      }
    },
    "solver_time_ms": {
      "type": "number",
      "minimum": 0
    },
    "time_breakdown": {
      "type": "object"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "path_found": {
            "const": true
          }
        }
      },
      "then": {
        "required": [
          "path_cost"
        ]
      }
    }
  ]
}
