{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BRIDGE Health Check Result v2",
  "type": "object",
  "required": [
    "schema_version",
    "profile",
    "run_validations",
    "regression_evaluation",
    "summary",
    "source_schema_version",
    "source_artifact_sha256",
    "generated_at"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.health.result.v1"
    },
    "source_artifact_id": {
      "type": "string"
    },
    "profile": {
      "type": "object"
    },
    "run_validations": {
      "type": "array"
    },
    "paired_comparisons": {
      "type": "array"
    },
    "regression_evaluation": {
      "type": "object"
    },
    "summary": {
      "type": "object"
    },
    "source_schema_version": {
      "type": "string"
    },
    "source_artifact_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "generated_at": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
