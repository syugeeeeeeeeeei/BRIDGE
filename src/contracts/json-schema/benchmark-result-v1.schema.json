{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bridge.local/schemas/benchmark-artifact-v2.schema.json",
  "title": "BRIDGE Benchmark Artifact v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "terminology_version",
    "suite_id",
    "run_metadata",
    "execution",
    "runs",
    "scenario_summaries"
  ],
  "properties": {
    "schema_version": {
      "const": "bridge.benchmark.artifact.v2"
    },
    "terminology_version": {
      "const": "bridge.terminology.v1"
    },
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "artifact_id": {
      "type": "string"
    },
    "run_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_schema_version",
        "started_at",
        "duration_ms",
        "execution_succeeded",
        "observation_mode"
      ],
      "properties": {
        "scenario_schema_version": {
          "const": "bridge.benchmark.v2"
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        },
        "completed_at": {
          "type": "string",
          "format": "date-time"
        },
        "duration_ms": {
          "type": "number",
          "minimum": 0
        },
        "execution_succeeded": {
          "type": "boolean"
        },
        "observation_mode": {
          "enum": ["off", "aggregate", "trace"]
        },
        "observation_sample_rate": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "output_metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "randomized",
        "run_order"
      ],
      "properties": {
        "randomized": {
          "type": "boolean"
        },
        "shuffle_seed": {
          "type": "integer"
        },
        "shuffle_algorithm": {
          "type": "string"
        },
        "run_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "environment": {
      "type": "object"
    },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/run"
      }
    },
    "scenario_summaries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/summary"
      }
    },
    "failures": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "run": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "run_metadata",
        "scenario_definition",
        "graph_profile",
        "query_profile",
        "algorithm_configuration",
        "execution_result",
        "measurement",
        "observations",
        "references"
      ],
      "properties": {
        "run_metadata": {
          "type": "object"
        },
        "scenario_definition": {
          "type": "object"
        },
        "graph_profile": {
          "type": "object"
        },
        "query_profile": {
          "type": "object"
        },
        "algorithm_configuration": {
          "type": "object"
        },
        "execution_result": {
          "type": "object"
        },
        "measurement": {
          "type": "object"
        },
        "observations": {
          "type": "object"
        },
        "references": {
          "type": "object"
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scenario_id",
        "algorithm",
        "query_id",
        "target_kind",
        "execution_path",
        "runs",
        "path_found_rate",
        "optimality_proven_rate",
        "mean_path_cost",
        "mean_work_actions",
        "mean_time_ms",
        "mean_solver_time_ms",
        "mean_end_to_end_time_ms",
        "work_statistics",
        "solver_time_statistics",
        "end_to_end_time_statistics",
        "metric_statistics"
      ],
      "properties": {
        "scenario_id": {
          "type": "string"
        },
        "algorithm": {
          "type": "string"
        },
        "query_id": {
          "type": "string"
        },
        "target_kind": {
          "type": "string"
        },
        "execution_path": {
          "type": "string"
        },
        "runs": {
          "type": "integer",
          "minimum": 0
        },
        "path_found_rate": {
          "type": "number"
        },
        "optimality_proven_rate": {
          "type": "number"
        },
        "mean_path_cost": {
          "type": "number"
        },
        "mean_work_actions": {
          "type": "number"
        },
        "mean_time_ms": {
          "type": "number"
        },
        "mean_solver_time_ms": {
          "type": "number"
        },
        "mean_end_to_end_time_ms": {
          "type": "number"
        },
        "min_distance": {
          "type": "number"
        },
        "max_distance": {
          "type": "number"
        },
        "work_statistics": {
          "type": "object"
        },
        "solver_time_statistics": {
          "type": "object"
        },
        "end_to_end_time_statistics": {
          "type": "object"
        },
        "metric_statistics": {
          "type": "object"
        },
        "failure_reasons": {
          "type": "object"
        },
        "ablation": {
          "type": "object"
        }
      }
    }
  }
}
