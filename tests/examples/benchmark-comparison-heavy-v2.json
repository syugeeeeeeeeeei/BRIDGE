{
  "schema_version": "bridge.benchmark.v2",
  "suite": {
    "id": "benchmark-comparison-heavy-v2",
    "description": "Heavier local comparison benchmark across multiple graph families and solver choices."
  },
  "execution": {
    "repetitions": 2,
    "warmup_runs": 1,
    "seeds": [11],
    "jobs": 1,
    "timeout": "45s",
    "randomize_order": true
  },
  "algorithms": [
    "bridge",
    "anchor",
    "bidirectional_dijkstra",
    "astar",
    "weighted_astar",
    "reachability"
  ],
  "observation_config": {
    "level": "trace",
    "sample_rate": 1.0
  },
  "output": {
    "output_dir": "./others/results/benchmark-comparison-heavy-v2",
    "artifact_id": "benchmark-comparison-heavy-v2",
    "save_raw_results": true,
    "save_graph_snapshot": true,
    "save_trace": false,
    "capture_environment": true,
    "metadata": {
      "purpose": "local-heavy-comparison",
      "timing_policy": "single-job-observation-off",
      "comparison_focus": "algorithm-behavior-across-graph-families"
    }
  },
  "scenarios": [
    {
      "id": "grid-open-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "open"
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 250000,
        "timeout_ms": 12000
      }
    },
    {
      "id": "grid-wall-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "wall",
        "edge_weight_noise": 0.03
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 300000,
        "timeout_ms": 12000
      }
    },
    {
      "id": "grid-u-shape-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "u_shape",
        "edge_weight_noise": 0.03
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 400000,
        "timeout_ms": 18000
      }
    },
    {
      "id": "random-geometric-1000",
      "graph": {
        "generator": "random_geometric",
        "requested_node_count": 1000,
        "neighbor_candidate_count": 8
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 300000,
        "timeout_ms": 15000
      }
    },
    {
      "id": "community-1000",
      "graph": {
        "generator": "community",
        "requested_node_count": 1000,
        "community_count": 8
      },
      "queries": [
        {
          "id": "default",
          "query_selection_method": "generator_default_endpoints"
        }
      ],
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 350000,
        "timeout_ms": 15000
      }
    },
    {
      "id": "maze-1000",
      "graph": {
        "generator": "maze",
        "requested_node_count": 1000
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 350000,
        "timeout_ms": 15000
      }
    }
  ]
}
