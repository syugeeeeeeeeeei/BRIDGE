{
  "schema_version": "bridge.benchmark.v3",
  "suite": {
    "id": "benchmark-comparison-heavy-v2",
    "description": "Heavier local comparison benchmark across multiple graph families and solver choices."
  },
  "execution": {
    "repetitions": 2,
    "warmup_runs": 1,
    "seeds": [
      11
    ],
    "randomize_order": true,
    "run_timeout": "45s"
  },
  "algorithms": [
    "bridge",
    "anchor",
    "bidirectional_dijkstra",
    "astar",
    "weighted_astar",
    "reachability"
  ],
  "output": {
    "directory": "./others/results/benchmark-comparison-heavy-v2"
  },
  "scenarios": [
    {
      "id": "grid-open-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "open"
      },
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 250000,
        "search_time_limit": "12.0s"
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ]
    },
    {
      "id": "grid-wall-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "wall",
        "edge_weight_noise": 0.03
      },
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 300000,
        "search_time_limit": "12.0s"
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ]
    },
    {
      "id": "grid-u-shape-1000",
      "graph": {
        "generator": "grid",
        "requested_node_count": 1000,
        "topology": "u_shape",
        "edge_weight_noise": 0.03
      },
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 400000,
        "search_time_limit": "18.0s"
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ]
    },
    {
      "id": "random-geometric-1000",
      "graph": {
        "generator": "random_geometric",
        "requested_node_count": 1000,
        "neighbor_candidate_count": 8
      },
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 300000,
        "search_time_limit": "15.0s"
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ]
    },
    {
      "id": "community-1000",
      "graph": {
        "generator": "community",
        "requested_node_count": 1000,
        "community_count": 8
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ],
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 350000,
        "search_time_limit": "15.0s"
      }
    },
    {
      "id": "maze-1000",
      "graph": {
        "generator": "maze",
        "requested_node_count": 1000
      },
      "route": {
        "logical_worker_count": 1,
        "mode": "balanced"
      },
      "budget": {
        "work_limit": 350000,
        "search_time_limit": "15.0s"
      },
      "queries": [
        {
          "id": "default",
          "selection": {
            "method": "generator_default"
          }
        }
      ]
    }
  ],
  "observation": {
    "mode": "trace"
  }
}
