{
  "schema_version": "bridge.benchmark.v2",
  "suite": {
    "id": "benchmark-smoke-v2",
    "description": "Small benchmark scenario for quick local verification of benchmark execution."
  },
  "execution": {
    "repetitions": 1,
    "warmup_runs": 0,
    "seeds": [1],
    "jobs": 1,
    "timeout": "15s",
    "randomize_order": false
  },
  "algorithms": [
    "bridge",
    "dijkstra",
    "astar",
    "reachability"
  ],
  "observation_config": {
    "level": "off",
    "sample_rate": 1.0
  },
  "scenarios": [
    {
      "id": "grid-open-25",
      "graph": {
        "generator": "grid",
        "requested_node_count": 25,
        "topology": "open"
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 50000,
        "timeout_ms": 5000
      }
    },
    {
      "id": "random-geometric-32",
      "graph": {
        "generator": "random_geometric",
        "requested_node_count": 32,
        "neighbor_candidate_count": 6
      },
      "endpoints": {
        "query_selection_method": "generator_default_endpoints"
      },
      "route": {
        "route_mode": "balanced",
        "logical_worker_count": 1
      },
      "budget": {
        "total_work": 50000,
        "timeout_ms": 5000
      }
    }
  ]
}
