    {"id":"maze-256","graph":{"generator":"maze","nodes":256},"queries":[{"id":"diameter","strategy":"opposite-corners"}],"route":{"mode":"balanced","workers":1}},
    {"id":"adversarial-256","graph":{"generator":"adversarial","nodes":256},"queries":[{"id":"diameter","strategy":"opposite-corners"}],"route":{"mode":"balanced","workers":1}}
  ]
}
