{
  "schema_version": "bridge.benchmark.v1",
  "suite": {
    "id": "bridge-performance-evaluation-v1",
    "description": "Research-grade comparative evaluation of BRIDGE and ANCHOR across representative graph families, obstacle structures, scales, and deterministic graph instances. Timing runs use observation=off; raw run records and environment metadata are retained for statistical analysis."
  },
  "execution": {
    "repetitions": 3,
    "warmup_runs": 1,
    "seeds": [104729, 130363],
    "jobs": 1,
    "timeout": "120s",
    "randomize_order": true
  },
  "algorithms": [
    "bridge",
    "anchor",
    "bidirectional_dijkstra",
    "astar",
    "weighted_astar",
    "reachability"
  ],
  "observation": {
    "mode": "off",
    "sample_rate": 1.0
  },
  "output": {
    "output_dir": "./others/results/bridge-performance-evaluation-v1",
    "artifact_id": "bridge-performance-evaluation-v1",
    "save_raw_results": true,
    "save_trace": false,
    "capture_environment": true,
    "metadata": {
      "purpose": "comparative-performance-evaluation",
      "statistical_unit": "scenario-algorithm-seed-query-repetition",
      "timing_policy": "observation-off-and-single-job",
      "graph_policy": "fixed-within-seed-across-repetitions-and-algorithms",
      "quality_reference": "exact-shortest-path-baselines"
    }
  },
  "scenarios": [
    {
      "id": "grid-open-4096",
      "graph": {"generator": "grid", "nodes": 4096, "topology": "open"},
      "queries": [{"id": "corners", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "grid-wall-4096",
      "graph": {"generator": "grid", "nodes": 4096, "topology": "wall", "noise": 0.02},
      "queries": [{"id": "corners", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "grid-u-shape-4096",
      "graph": {"generator": "grid", "nodes": 4096, "topology": "u_shape", "noise": 0.02},
      "queries": [{"id": "corners", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "grid-culdesac-4096",
      "graph": {"generator": "grid", "nodes": 4096, "topology": "culdesac", "noise": 0.02},
      "queries": [{"id": "corners", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "grid-disconnected-4096",
      "graph": {"generator": "grid", "nodes": 4096, "topology": "disconnected", "noise": 0.02},
      "queries": [{"id": "corners", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "random-geometric-4096",
      "graph": {"generator": "random_geometric", "nodes": 4096, "k": 8},
      "queries": [{"id": "diameter", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "community-4096",
      "graph": {"generator": "community", "nodes": 4096, "communities": 16},
      "queries": [{"id": "cross-community", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "maze-4096",
      "graph": {"generator": "maze", "nodes": 4096},
      "queries": [{"id": "diameter", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    },
    {
      "id": "adversarial-4096",
      "graph": {"generator": "adversarial", "nodes": 4096},
      "queries": [{"id": "diameter", "strategy": "opposite-corners"}],
      "route": {"mode": "balanced", "workers": 1}
    }
  ]
}
